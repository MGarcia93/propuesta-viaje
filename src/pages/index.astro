---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import TripCatalog from '../components/home/TripCatalog.astro';
import QuickComparisonTable from '../components/home/QuickComparisonTable.astro';
import CallToAction from '../components/home/CallToAction.astro';
import Footer from '../components/home/Footer.astro';
import { getTripCardProjections } from '../lib/trips';

const trips = await getTripCardProjections();
---

<Layout
  title="Viaje Tanto — ¿A dónde nos vamos?"
  description="Tres propuestas, tres formas completamente distintas de viajar y una sola decisión. Explorá, compará y encontrá tu próximo viaje."
>
  <HeroSection />

  <!-- Catalog section -->
  <section id="catalog" class="w-full px-6 py-16 md:px-12 md:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-2 mb-10">
        <h2 class="font-display text-display-lg text-text-primary">
          Las propuestas
        </h2>
        <p class="text-text-secondary max-w-2xl">
          Hacé clic en cualquiera. En lugar de abrir una ficha común, entrás en una presentación
          pensada para que el viaje se sienta antes de vivirlo.
        </p>
      </div>

      <TripCatalog trips={trips} />
    </div>
  </section>

  <QuickComparisonTable trips={trips} />
  <CallToAction />
  <Footer />
</Layout>
