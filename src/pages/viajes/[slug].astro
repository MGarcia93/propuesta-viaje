---
import Layout from '../../layouts/Layout.astro';
import SlideRenderer from '../../components/presentation/SlideRenderer.astro';
import PresentationControls from '../../components/presentation/PresentationControls.astro';
import TripDetailFallback from '../../components/presentation/TripDetailFallback.astro';
import { getTripCardProjections, getTripBySlug } from '../../lib/trips';

export async function getStaticPaths() {
  const projections = await getTripCardProjections();
  return projections.map((trip) => ({
    params: { slug: trip.slug },
  }));
}

const { slug } = Astro.params;
const trip = await getTripBySlug(slug!);

if (!trip) {
  return Astro.redirect('/404');
}

const slides = trip.slides ?? [];
const totalSlides = slides.length;
const hasSlides = totalSlides > 0;
---

<Layout
  title={`${trip.catalog.title} — Viaje Tanto`}
  description={trip.catalog.summary}
>

  {hasSlides ? (
    <!-- Presentation mode -->
    <div
      class="relative min-h-screen bg-surface"
      data-controller
      data-overlay="false"
      data-return-url="/"
    >
      <!-- Slides container -->
      <div class="slide-track">
        {slides.map((slide) => (
          <div key={slide.id} data-slide class="min-h-screen w-full" style="display: none;" tabindex="-1">
            <SlideRenderer slide={slide} trip={trip} />
          </div>
        ))}
      </div>

      <!-- Controls -->
      <PresentationControls
        trip={trip}
        totalSlides={totalSlides}
        returnUrl="/"
      />
    </div>
  ) : (
    <TripDetailFallback trip={trip} />
  )}
</Layout>
