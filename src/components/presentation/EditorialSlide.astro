---
import type { Trip } from '../../schemas/trip.schema';

export interface Props {
  slide: Trip['slides'][number];
  trip: Trip;
}

const { slide } = Astro.props;
const slideId = `slide-${slide.id}`;
const layout = slide.layout ?? 'default';
---

<section
  id={slideId}
  class="slide-container items-center justify-center px-6 py-16 md:px-12"
>
  <article class="w-full max-w-2xl text-center">
    {slide.title && (
      <h2 class="font-display text-display-md text-text-primary mb-4 leading-tight">
        {slide.title}
      </h2>
    )}

    {slide.subtitle && (
      <p class="text-lg text-text-secondary mb-6 font-display">
        {slide.subtitle}
      </p>
    )}

    {slide.text && (
      <div class="prose prose-invert max-w-none text-text-secondary leading-relaxed">
        {slide.text.split('\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    )}

    {slide.image && (
      <figure class="mt-8">
        <img
          src={slide.image}
          alt={slide.title ?? ''}
          class="w-full rounded-xl object-cover"
          loading="lazy"
        />
      </figure>
    )}

    {slide.images && slide.images.length > 0 && (
      <div class={`mt-8 grid gap-4 ${
        slide.images.length === 1 ? 'grid-cols-1' :
        slide.images.length === 2 ? 'grid-cols-1 sm:grid-cols-2' :
        'grid-cols-1 sm:grid-cols-2 md:grid-cols-3'
      }`}>
        {slide.images.map((img) => (
          <figure key={img.alt} class="overflow-hidden rounded-lg">
            {img.src && (
              <img
                src={img.src}
                alt={img.alt}
                class="h-48 w-full object-cover"
                loading="lazy"
              />
            )}
            {img.caption && (
              <figcaption class="mt-1 text-xs text-text-muted px-1">
                {img.caption}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    )}
  </article>
</section>
