---
import type { Trip } from '../../schemas/trip.schema';

export interface Props {
  slide: Trip['slides'][number];
  trip: Trip;
}

const { slide, trip } = Astro.props;
const slideId = `slide-${slide.id}`;
const pace = trip.paceSummary;
const catalogPace = trip.catalog?.pace;

const paceColor: Record<string, string> = {
  relaxed: 'bg-green-500/20 text-green-400 border-green-500/30',
  moderate: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  intense: 'bg-brand-coral/20 text-brand-coral border-brand-coral/30',
};

const paceLabel: Record<string, string> = {
  relaxed: 'Relajado',
  moderate: 'Moderado',
  intense: 'Intenso',
};
---

<section
  id={slideId}
  class="slide-container items-center justify-center px-6 py-16 md:px-12"
>
  <div class="w-full max-w-4xl">
    {slide.title && (
      <h2 class="font-display text-display-md text-text-primary mb-2">
        {slide.title}
      </h2>
    )}

    {slide.subtitle && (
      <p class="text-text-secondary mb-8">{slide.subtitle}</p>
    )}

    {catalogPace && (
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-semibold {paceColor[catalogPace] ?? 'pill-surface'}">
        <span>Ritmo: {paceLabel[catalogPace] ?? catalogPace}</span>
      </div>
    )}

    {pace ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {pace.description && (
          <div class="col-span-full rounded-lg bg-surface-card border border-surface-border p-4">
            <p class="text-sm text-text-secondary leading-relaxed">{pace.description}</p>
          </div>
        )}

        {pace.relaxedDays != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-green-400">{pace.relaxedDays}</span>
            <p class="text-xs text-text-muted mt-1">Días relajados</p>
          </div>
        )}

        {pace.moderateDays != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-yellow-400">{pace.moderateDays}</span>
            <p class="text-xs text-text-muted mt-1">Días moderados</p>
          </div>
        )}

        {pace.intenseDays != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-brand-coral">{pace.intenseDays}</span>
            <p class="text-xs text-text-muted mt-1">Días intensos</p>
          </div>
        )}

        {pace.accommodationChanges != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-text-primary">{pace.accommodationChanges}</span>
            <p class="text-xs text-text-muted mt-1">Cambios de alojamiento</p>
          </div>
        )}

        {pace.longTransfers != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-text-primary">{pace.longTransfers}</span>
            <p class="text-xs text-text-muted mt-1">Traslados largos</p>
          </div>
        )}

        {pace.freeTimeDays != null && (
          <div class="rounded-lg border border-surface-border bg-surface-card p-4">
            <span class="text-2xl font-bold text-text-primary">{pace.freeTimeDays}</span>
            <p class="text-xs text-text-muted mt-1">Días con tiempo libre</p>
          </div>
        )}
      </div>
    ) : (
      <p class="text-text-muted italic">No hay información de ritmo disponible.</p>
    )}
  </div>
</section>
