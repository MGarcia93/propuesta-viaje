---
import type { Trip } from '../../schemas/trip.schema';
import { resolveSlideSource } from '../../lib/slides';

export interface Props {
  slide: Trip['slides'][number];
  trip: Trip;
}

const { slide, trip } = Astro.props;
const slideId = `slide-${slide.id}`;

// Resolve itinerary from sourceRef or use full itinerary
let itinerary: Trip['itinerary'];

if (slide.sourceRef) {
  const source = resolveSlideSource(trip, slide.sourceRef);
  if (source.type === 'reference' && Array.isArray(source.data)) {
    itinerary = source.data as Trip['itinerary'];
  } else {
    itinerary = trip.itinerary ?? [];
  }
} else {
  itinerary = trip.itinerary ?? [];
}
---

<section
  id={slideId}
  class="slide-container items-center justify-center px-6 py-16 md:px-12"
>
  <div class="w-full max-w-4xl">
    {slide.title && (
      <h2 class="font-display text-display-md text-text-primary mb-2">
        {slide.title}
      </h2>
    )}

    {slide.subtitle && (
      <p class="text-text-secondary mb-8">{slide.subtitle}</p>
    )}

    {itinerary.length > 0 ? (
      <div class="space-y-4">
        {itinerary.map((day) => (
          <div
            key={day.day}
            class="rounded-xl border border-surface-border bg-surface-card overflow-hidden"
          >
            <!-- Day header -->
            <div class="flex items-center gap-3 bg-surface-hover px-4 py-3">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-coral/15 text-brand-orange text-xs font-bold">
                {day.day}
              </span>
              <div class="flex-1">
                <span class="text-sm font-semibold text-text-primary">
                  {day.title ?? `Día ${day.day}`}
                </span>
                {day.city && (
                  <span class="ml-2 text-xs text-text-muted">{day.city}</span>
                )}
              </div>
              {day.intensity && (
                <span class={`text-[10px] uppercase tracking-wider ${
                  day.intensity === 'intense' ? 'text-brand-coral' :
                  day.intensity === 'moderate' ? 'text-yellow-400' :
                  'text-green-400'
                }`}>
                  {day.intensity}
                </span>
              )}
            </div>

            <!-- Day content -->
            <div class="px-4 py-3">
              {day.summary && (
                <p class="text-sm text-text-secondary mb-2">{day.summary}</p>
              )}

              <div class="grid gap-2 sm:grid-cols-3">
                {day.morning && day.morning.length > 0 && (
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-text-dim">Mañana</span>
                    <ul class="mt-1 space-y-0.5">
                      {day.morning.map((item, i) => (
                        <li key={i} class="text-xs text-text-secondary">• {item}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {day.afternoon && day.afternoon.length > 0 && (
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-text-dim">Tarde</span>
                    <ul class="mt-1 space-y-0.5">
                      {day.afternoon.map((item, i) => (
                        <li key={i} class="text-xs text-text-secondary">• {item}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {day.evening && day.evening.length > 0 && (
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-text-dim">Noche</span>
                    <ul class="mt-1 space-y-0.5">
                      {day.evening.map((item, i) => (
                        <li key={i} class="text-xs text-text-secondary">• {item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              {day.transport && (
                <p class="mt-2 text-[10px] text-text-muted flex items-center gap-1">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  {day.transport}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-text-muted italic">No hay itinerario disponible.</p>
    )}
  </div>
</section>
