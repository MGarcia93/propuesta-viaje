---
import type { Trip } from '../../schemas/trip.schema';

export interface Props {
  slide: Trip['slides'][number];
  trip: Trip;
}

const { slide } = Astro.props;
const slideId = `slide-${slide.id}`;
---

<section
  id={slideId}
  class="relative flex min-h-[80vh] w-full flex-col items-center justify-center overflow-hidden"
>
  {slide.image ? (
    <img
      src={slide.image}
      alt={slide.title ?? ''}
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
  ) : (
    <div class="absolute inset-0 bg-surface-darker" />
  )}

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-surface/80 via-surface/30 to-surface/40" />

  <div class="relative z-10 flex w-full max-w-3xl flex-col items-center justify-center px-6 text-center">
    {slide.title && (
      <h2 class="font-display text-display-md text-text-primary mb-3 leading-tight">
        {slide.title}
      </h2>
    )}

    {slide.subtitle && (
      <p class="text-lg text-text-secondary mb-4">{slide.subtitle}</p>
    )}

    {slide.text && (
      <p class="max-w-2xl text-text-secondary leading-relaxed">
        {slide.text}
      </p>
    )}
  </div>
</section>
