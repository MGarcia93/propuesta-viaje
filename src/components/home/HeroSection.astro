---
interface Props {
  tripCount?: number;
}

const { tripCount = 3 } = Astro.props;
---

<section class="hero-section relative flex min-h-screen w-full flex-col items-center justify-center overflow-hidden bg-surface-darker">
  <!-- Hero background image -->
  <div class="hero-bg absolute inset-0 bg-cover bg-center bg-no-repeat opacity-40" />
  
  <!-- Gradient overlays for readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-surface/70 via-surface/40 to-surface" />
  <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/5 via-transparent to-brand-coral/5" />

  <div class="relative z-10 flex w-full max-w-5xl flex-col items-center px-6 text-center">
    <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-orange mb-6">
      Propuestas para 2027
    </span>

    <h1 class="font-display text-display-xl text-text-primary leading-none mb-6">
      ¿A dónde nos vamos?
    </h1>

    <p class="max-w-2xl text-lg text-text-secondary mb-10">
      {tripCount} {tripCount === 1 ? 'propuesta' : 'propuestas'}, {tripCount === 1 ? 'una forma' : `${tripCount} formas completamente distintas`} de viajar y una sola decisión.
      Explorá {tripCount === 1 ? 'la propuesta' : 'cada una'}, {tripCount === 1 ? 'descubrila' : 'comparalas'} y encontrá la que más te representa.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#catalog"
        class="inline-flex items-center gap-2 rounded-full bg-brand-coral px-6 py-3 text-sm font-semibold text-white hover:bg-brand-coral/90 transition-colors focus-visible:outline-2 focus-visible:outline-brand-orange"
      >
        Explorar {tripCount === 1 ? 'la propuesta' : 'propuestas'}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
      {tripCount > 1 && (
        <a
          href="/comparar"
          class="inline-flex items-center gap-2 rounded-full border border-surface-border px-6 py-3 text-sm font-semibold text-text-secondary hover:text-text-primary hover:bg-surface-card transition-colors focus-visible:outline-2 focus-visible:outline-brand-orange"
        >
          Compararlas
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="h-5 w-5 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  /* 
   * To set a hero background image, either:
   * 1. Replace the URL below with your image path
   * 2. Or set via inline style on .hero-bg: style="background-image: url('/hero.jpg')"
   */
  .hero-bg {
    background-image: url('https://images.unsplash.com/photo-1508804185872-d7badad00f7d?w=1920&q=80');
  }

  /* Parallax effect on scroll */
  @media (prefers-reduced-motion: no-preference) {
    .hero-bg {
      transform: translateZ(0);
      will-change: transform;
    }
  }
</style>
